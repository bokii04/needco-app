import { useState } from "react";
import { useApp } from "../context/AppContext";
import { supabase } from "../supabase";

export default function LoginScreen() {
  const { login } = useApp();
  const [phone, setPhone] = useState("");
  const [otp, setOtp] = useState("");
  const [otpSent, setOtpSent] = useState(false);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const handleGoogle = async () => {
    await supabase.auth.signInWithOAuth({
      provider: "google",
      options: { redirectTo: window.location.origin }
    });
  };

  const handleFacebook = async () => {
    await supabase.auth.signInWithOAuth({
      provider: "facebook",
      options: { redirectTo: window.location.origin }
    });
  };

  const handleSendOTP = async () => {
    setLoading(true);
    setError("");
    const { error } = await supabase.auth.signInWithOtp({ phone });
    if (error) setError(error.message);
    else setOtpSent(true);
    setLoading(false);
  };

  const handleVerifyOTP = async () => {
    setLoading(true);
    setError("");
    const { error } = await supabase.auth.verifyOtp({ phone, token: otp, type: "sms" });
    if (error) setError(error.message);
    setLoading(false);
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", flex: 1, minHeight: 720 }}>
      {/* Hero */}
      <div style={{ background: "var(--green)", padding: "52px 28px 40px", position: "relative", overflow: "hidden" }}>
        <div style={{ position: "absolute", top: -40, right: -40, width: 180, height: 180, borderRadius: "50%", background: "rgba(255,255,255,0.08)" }} />
        <div style={{ position: "absolute", bottom: -20, left: 20, width: 120, height: 120, borderRadius: "50%", background: "rgba(255,255,255,0.06)" }} />
        <div className="fade-up" style={{ position: "relative" }}>
          <div style={{ width: 52, height: 52, background: "rgba(255,255,255,0.2)", borderRadius: 14, display: "flex", alignItems: "center", justifyContent: "center", marginBottom: 18, fontSize: 24 }}>N</div>
          <h1 style={{ color: "#fff", fontSize: 32, marginBottom: 8 }}>Need.co</h1>
          <p style={{ color: "rgba(255,255,255,0.75)", fontSize: 14, margin: 0 }}>Services at your doorstep</p>
        </div>
      </div>

      {/* Form */}
      <div style={{ flex: 1, padding: "28px 24px 32px" }}>

        {/* Social logins */}
        <div className="fade-up-1" style={{ display: "flex", flexDirection: "column", gap: 12, marginBottom: 24 }}>
          <button onClick={handleGoogle} className="btn" style={{
            background: "#fff", border: "1px solid var(--border-mid)", color: "var(--text)",
            display: "flex", alignItems: "center", justifyContent: "center", gap: 10
          }}>
            <span style={{ fontSize: 18 }}>G</span> Continue with Google
          </button>
          <button onClick={handleFacebook} className="btn" style={{
            background: "#1877F2", border: "none", color: "#fff",
            display: "flex", alignItems: "center", justifyContent: "center", gap: 10
          }}>
            <span style={{ fontSize: 18 }}>f</span> Continue with Facebook
          </button>
        </div>

        {/* Divider */}
        <div className="fade-up-2" style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 24 }}>
          <div style={{ flex: 1, height: 1, background: "var(--border)" }} />
          <span style={{ fontSize: 12, color: "var(--text-muted)", fontFamily: "var(--font-display)", fontWeight: 600 }}>or use phone number</span>
          <div style={{ flex: 1, height: 1, background: "var(--border)" }} />
        </div>

        {/* Phone login */}
        {!otpSent ? (
          <div className="fade-up-3">
            <div className="input-wrap">
              <label className="input-label">Phone number</label>
              <div style={{ display: "flex", gap: 8 }}>
                <div style={{ padding: "12px 14px", border: "1px solid var(--border-mid)", borderRadius: "var(--radius-sm)", fontSize: 14, color: "var(--text)", background: "var(--surface-2)", whiteSpace: "nowrap" }}>🇵🇭 +63</div>
                <input className="input-field" placeholder="9xx xxx xxxx" value={phone} onChange={e => setPhone("+63" + e.target.value.replace(/^0/, ""))} style={{ flex: 1 }} />
              </div>
            </div>
            {error && <p style={{ color: "var(--danger)", fontSize: 12, marginBottom: 12 }}>{error}</p>}
            <button className="btn btn-primary" onClick={handleSendOTP} disabled={loading || !phone}>
              {loading ? "Sending..." : "Send OTP"}
            </button>
          </div>
        ) : (
          <div className="fade-up-3">
            <div className="input-wrap">
              <label className="input-label">Enter OTP sent to {phone}</label>
              <input className="input-field" placeholder="6-digit code" value={otp} onChange={e => setOtp(e.target.value)} maxLength={6} />
            </div>
            {error && <p style={{ color: "var(--danger)", fontSize: 12, marginBottom: 12 }}>{error}</p>}
            <button className="btn btn-primary" onClick={handleVerifyOTP} disabled={loading || otp.length < 6}>
              {loading ? "Verifying..." : "Verify & Sign in"}
            </button>
            <button className="btn btn-secondary" style={{ marginTop: 8 }} onClick={() => setOtpSent(false)}>
              Change number
            </button>
          </div>
        )}
      </div>
    </div>
  );x
